{
  "name": "lowhofer-planner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "local:env": "node scripts/writeLocalDevVars.mjs",
    "local:db:start": "npx supabase start",
    "local:db:stop": "npx supabase stop",
    "local:db:reset": "node scripts/localInstall.mjs",
    "local:testdata": "node scripts/generateLocalTestData.mjs",
    "local:services:start": "npm run local:db:start && npm run local:env",
    "local:setup": "node scripts/localInstall.mjs",
    "local:reset": "node scripts/localInstall.mjs",
    "local:api": "wrangler pages dev public --port 8789",
    "local:dev": "npm run local:services:start && concurrently -k -n api,ui \"npm:local:api\" \"npm:dev\"",
    "pages:local": "npm run local:services:start && npm run local:api",
    "local:start": "npm run local:services:start",
    "local:install": "npm run local:setup",
    "pages:dev": "npm run build && wrangler pages dev dist",
    "pages:deploy": "npm run build && wrangler pages deploy dist",
    "deploy": "npm run pages:deploy",
    "import:league": "node scripts/importLeagueData.mjs",
    "hash:password": "node scripts/createPasswordHash.mjs",
    "wrangler:version": "wrangler --version"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "daisyui": "^4.12.24",
    "lucide-react": "^1.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260415.1",
    "@eslint/js": "^9.37.0",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "eslint": "^9.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "postcss": "^8.5.6",
    "supabase": "^2.93.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.1",
    "vite": "^7.1.10",
    "vitest": "^4.1.4",
    "wrangler": "^4.82.2"
  }
}
